# Supabase — enables accounts + cross-device progress sync.
# 1. Create a free project at https://supabase.com
# 2. Project Settings -> API -> copy "Project URL" and the "anon / public" key
# 3. Copy this file to `.env` (gitignored) and paste the values below
# 4. In the Supabase SQL editor, run supabase/schema.sql once
#
# Leave these blank and the app runs exactly as before: local-only, no accounts.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
